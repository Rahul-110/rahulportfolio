---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import { caseStudies } from "../../content/caseStudies";

export function getStaticPaths() {
  return caseStudies.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props;
---

<BaseLayout title={`${c.title} — Case Study`} description={c.summary}>
  <main class="min-h-dvh py-10">
    <Container>
      <a href="/#work" class="inline-flex items-center gap-2 text-xs font-semibold text-[--muted] hover:text-[--text]">
        <span aria-hidden="true">←</span> Back to work
      </a>

      <header class="mt-8 overflow-hidden rounded-[--radius-lg] border border-[--border] bg-[--surface] p-7 shadow-[--shadow-sm]">
        <div
          class="pointer-events-none absolute -right-24 -top-24 size-72 rounded-full blur-3xl"
          style={`background: radial-gradient(circle, ${c.accent}, transparent 60%);`}
        />
        <p class="text-xs font-semibold tracking-[0.2em] text-[--muted2] uppercase">{c.role} · {c.year}</p>
        <h1 class="mt-3 font-display text-4xl tracking-tight sm:text-5xl">{c.title}</h1>
        <p class="mt-4 max-w-2xl text-sm sm:text-base text-muted">{c.summary}</p>

        <div class="mt-6 flex flex-wrap gap-2">
          {c.tags.map((t) => (
            <span class="rounded-full border border-[--border] bg-[rgba(255,255,255,0.02)] px-3 py-1 text-xs font-semibold text-[--muted]">
              {t}
            </span>
          ))}
        </div>
      </header>

      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {c.outcomes.map((o) => (
          <div class="glass card p-5">
            <div class="text-xs font-semibold tracking-[0.2em] text-[--muted2] uppercase">{o.label}</div>
            <div class="mt-2 font-display text-2xl tracking-tight">{o.value}</div>
          </div>
        ))}
      </div>

      <section class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="md:col-span-1">
          <h2 class="font-display text-2xl tracking-tight">Problem</h2>
          <p class="mt-3 text-sm text-muted">
            The fastest way to communicate impact is a crisp, constraint-aware problem statement.
          </p>
        </div>
        <div class="md:col-span-2 space-y-3">
          {c.problem.map((p) => (
            <div class="card bg-[--surface] px-5 py-4 hairline text-sm text-[--muted]">{p}</div>
          ))}
        </div>
      </section>

      <section class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="md:col-span-1">
          <h2 class="font-display text-2xl tracking-tight">Process</h2>
          <p class="mt-3 text-sm text-muted">
            Structured beats with artifacts. (Later we can add images, flows, and UI shots using `astro:assets`.)
          </p>
        </div>
        <div class="md:col-span-2 space-y-4">
          {c.process.map((s) => (
            <div class="glass rounded-[--radius-lg] p-6">
              <div class="text-sm font-semibold">{s.title}</div>
              <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-muted">
                {s.points.map((x) => (
                  <li>{x}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="md:col-span-1">
          <h2 class="font-display text-2xl tracking-tight">Final UI</h2>
          <p class="mt-3 text-sm text-muted">
            Outcome-focused: what users see and feel—aligned to the original constraints.
          </p>
        </div>
        <div class="md:col-span-2 space-y-3">
          {c.finalUI.map((x) => (
            <div class="card bg-[--surface] px-5 py-4 hairline text-sm text-[--muted]">{x}</div>
          ))}
        </div>
      </section>

      {c.links?.length ? (
        <section class="mt-12">
          <h2 class="font-display text-2xl tracking-tight">Links</h2>
          <div class="mt-4 flex flex-wrap gap-3">
            {c.links.map((l) => (
              <a class="btn btn-secondary" href={l.href} target="_blank" rel="noreferrer">
                {l.label} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      ) : null}

      <footer class="mt-16 pb-16">
        <div class="h-px bg-[--border]" />
        <p class="mt-8 text-xs text-muted2">
          Built with Astro + performance-budgeted motion. Reduced-motion users get a clean, static experience.
        </p>
      </footer>
    </Container>
  </main>
</BaseLayout>

