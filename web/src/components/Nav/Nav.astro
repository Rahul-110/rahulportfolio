---
import Container from "../ui/Container.astro";

type Link = { href: string; label: string };

const links: Link[] = [
  { href: "#work", label: "Work" },
  { href: "#story", label: "Story" },
  { href: "#skills", label: "Skills" },
  { href: "#testimonials", label: "Testimonials" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-[--bg] to-transparent" />
  <Container class="py-4">
    <nav class="glass pointer-events-auto flex items-center justify-between rounded-full px-4 py-3 sm:px-5">
      <a href="#" class="flex items-center gap-2">
        <span class="grid size-9 place-items-center rounded-full bg-[--surface2] hairline">
          <span class="font-display text-sm font-semibold tracking-tight">R</span>
        </span>
        <span class="hidden text-sm font-semibold text-[--muted] sm:inline">UI/UX Designer</span>
      </a>

      <div class="hidden items-center gap-6 sm:flex">
        {links.map((l) => (
          <a
            href={l.href}
            class="text-xs font-semibold tracking-wide text-[--muted] transition hover:text-[--text]"
          >
            {l.label}
          </a>
        ))}
      </div>

      <a href="#contact" class="btn btn-primary px-4 py-2 text-xs">
        Hire Me
        <span aria-hidden="true">→</span>
      </a>
    </nav>
  </Container>
</header>

