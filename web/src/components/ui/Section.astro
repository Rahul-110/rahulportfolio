---
import Container from "./Container.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  class?: string;
};

const { id, eyebrow, title, subtitle, class: className = "" } = Astro.props;
---

<section id={id} class={`py-24 sm:py-28 ${className}`}>
  <Container>
    {(eyebrow || title || subtitle) && (
      <header class="mx-auto mb-14 max-w-2xl text-center">
        {eyebrow && (
          <p class="text-xs font-semibold tracking-[0.2em] text-[--muted2] uppercase">{eyebrow}</p>
        )}
        {title && <h2 class="mt-4 font-display text-3xl sm:text-4xl tracking-tight">{title}</h2>}
        {subtitle && <p class="mt-4 text-sm sm:text-base text-muted">{subtitle}</p>}
      </header>
    )}
    <slot />
  </Container>
</section>

