---
import Section from "../components/ui/Section.astro";
---

<Section
  id="skills"
  eyebrow="Skills & tools"
  title="Craft + systems"
  subtitle="A balanced profile: UX thinking, visual craft, and system-level consistency. Interactive bars + floating icons will be wired in next."
>
  <div class="grid gap-5 md:grid-cols-3">
    {[
      { t: "UX", d: "Research, flows, IA, usability testing", level: 92 },
      { t: "UI", d: "Visual hierarchy, design systems, components", level: 94 },
      { t: "Tools", d: "Figma, Prototyping, Hand-off, QA", level: 90 },
      { t: "Product", d: "Metrics, collaboration, prioritization", level: 84 },
      { t: "Motion", d: "Micro-interactions, easing, delight", level: 78 },
      { t: "Accessibility", d: "WCAG basics, contrast, keyboard UX", level: 82 },
    ].map((s) => (
      <div class="glass rounded-[--radius-lg] p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="font-display text-xl tracking-tight">{s.t}</div>
            <div class="mt-2 text-sm text-muted">{s.d}</div>
          </div>
          <div class="rounded-full bg-[--surface2] px-3 py-1 text-xs font-semibold text-[--muted] hairline">
            {s.level}%
          </div>
        </div>
        <div class="mt-5 h-1.5 overflow-hidden rounded-full bg-[rgba(255,255,255,0.06)]">
          <div
            class="h-full rounded-full"
            style={`width:${s.level}%; background: var(--accent-grad);`}
          />
        </div>
      </div>
    ))}
  </div>
</Section>

