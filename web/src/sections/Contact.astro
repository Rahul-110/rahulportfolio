---
import Section from "../components/ui/Section.astro";
---

<Section
  id="contact"
  eyebrow="Contact"
  title="Let’s build something premium"
  subtitle="A conversion-focused CTA with a minimal form. Next: animated button + success state + validation."
>
  <div class="grid gap-6 md:grid-cols-2 md:gap-10">
    <div class="glass rounded-[--radius-lg] p-6 sm:p-8">
      <h3 class="font-display text-2xl tracking-tight">What you’ll get</h3>
      <p class="mt-3 text-sm text-muted">
        A structured UX process, crisp visual hierarchy, and production-friendly design systems—optimized for fast
        decision-making from recruiters and hiring managers.
      </p>

      <div class="mt-7 space-y-3">
        {[
          "Case studies with clear Problem → Process → Final UI",
          "Premium motion—subtle, performant, purposeful",
          "Responsive by default; accessibility baked in",
        ].map((x) => (
          <div class="card bg-[--surface] px-4 py-3 hairline text-sm text-[--muted]">
            <span class="mr-2 text-[--text]">✓</span>
            {x}
          </div>
        ))}
      </div>
    </div>

    <div class="glass rounded-[--radius-lg] p-6 sm:p-8">
      <form class="space-y-4">
        <div>
          <label class="mb-1.5 block text-xs font-semibold tracking-wide text-[--muted2] uppercase" for="name"
            >Name</label
          >
          <input
            id="name"
            name="name"
            type="text"
            class="w-full card border border-[--border] bg-[rgba(255,255,255,0.02)] px-4 py-3 text-sm text-[--text] placeholder:text-[--muted2] focus:border-[rgba(167,139,250,0.45)] focus:outline-none"
            placeholder="Your name"
            autocomplete="name"
          />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold tracking-wide text-[--muted2] uppercase" for="email"
            >Email</label
          >
          <input
            id="email"
            name="email"
            type="email"
            class="w-full card border border-[--border] bg-[rgba(255,255,255,0.02)] px-4 py-3 text-sm text-[--text] placeholder:text-[--muted2] focus:border-[rgba(167,139,250,0.45)] focus:outline-none"
            placeholder="you@company.com"
            autocomplete="email"
          />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold tracking-wide text-[--muted2] uppercase" for="message"
            >Message</label
          >
          <textarea
            id="message"
            name="message"
            rows="5"
            class="w-full resize-none card border border-[--border] bg-[rgba(255,255,255,0.02)] px-4 py-3 text-sm text-[--text] placeholder:text-[--muted2] focus:border-[rgba(167,139,250,0.45)] focus:outline-none"
            placeholder="Tell me what you're hiring for…"
          ></textarea>
        </div>
        <button type="button" class="btn btn-primary w-full">
          Send message <span aria-hidden="true">→</span>
        </button>
        <p class="text-xs text-muted2">
          Prefer email? <a class="underline decoration-[rgba(255,255,255,0.25)] underline-offset-4 hover:decoration-[rgba(167,139,250,0.6)]" href="mailto:rahul@example.com">rahul@example.com</a>
        </p>
      </form>
    </div>
  </div>
</Section>

