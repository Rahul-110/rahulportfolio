---
import Container from "../components/ui/Container.astro";
import MouseParallax from "../components/motion/MouseParallax";
---

<section class="relative overflow-hidden pb-12 pt-14 sm:pb-16 sm:pt-20">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 opacity-70 [mask-image:radial-gradient(60%_60%_at_50%_20%,black,transparent)]">
      <div
        class="absolute -top-40 left-1/2 h-[720px] w-[720px] -translate-x-1/2 rounded-full blur-3xl"
        style="background: radial-gradient(circle at 30% 30%, rgba(167,139,250,.25), transparent 60%), radial-gradient(circle at 70% 60%, rgba(96,165,250,.18), transparent 55%);"
        data-parallax
        data-speed="0.22"
        data-axis="y"
        data-dir="up"
      />
    </div>
    <div
      class="absolute inset-0 opacity-[0.22]"
      style="background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 22px 22px;"
      data-parallax
      data-speed="0.08"
      data-axis="y"
      data-dir="down"
    />
    <div class="absolute inset-0 opacity-[0.05]" style="background: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27n%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.9%27 numOctaves=%274%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23n)%27/%3E%3C/svg%3E')" />
  </div>

  <Container>
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="mx-auto max-w-xl text-center lg:mx-0 lg:text-left">
        <div class="inline-flex items-center gap-2 rounded-full bg-[--surface] px-4 py-2 hairline">
          <span class="relative size-2 rounded-full bg-emerald-400">
            <span class="absolute inset-0 rounded-full bg-emerald-400 opacity-40 blur-[6px]" />
          </span>
          <span class="text-xs font-semibold tracking-wide text-[--muted]">Available for UI/UX roles (10 LPA+)</span>
        </div>

        <h1 class="mt-7 font-display text-5xl leading-[1.02] tracking-tight sm:text-6xl">
          Rahul <span class="grad-text">— UI/UX Designer</span>
        </h1>
        <p class="mt-6 text-base text-muted sm:text-lg">
          I design premium product experiences that feel effortless, communicate value fast, and convert—through
          sharp UX hierarchy, clean UI, and polished interactions.
        </p>

        <div class="mt-10 flex flex-col items-stretch gap-3 sm:flex-row sm:items-center">
          <a href="#work" class="btn btn-primary w-full sm:w-auto">
            View Work <span aria-hidden="true">→</span>
          </a>
          <a href="#contact" class="btn btn-secondary w-full sm:w-auto">
            Hire Me
          </a>
        </div>

        <div class="mt-10 grid grid-cols-3 gap-3 sm:gap-4">
          {[
            { k: "5+", v: "Years designing" },
            { k: "20+", v: "Shipped projects" },
            { k: "End-to-end", v: "Research → UI" },
          ].map((s) => (
          <div class="glass card px-4 py-4 text-left">
              <div class="font-display text-2xl tracking-tight">{s.k}</div>
              <div class="mt-1 text-xs text-muted">{s.v}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Floating UI mockup visual (subtle, does not overpower text) -->
      <div class="relative mx-auto w-full max-w-xl lg:max-w-none">
        <div
          class="pointer-events-none absolute -inset-6 -z-10 card opacity-80 blur-2xl"
          style="background: radial-gradient(circle at 30% 30%, rgba(167,139,250,.22), transparent 60%), radial-gradient(circle at 70% 55%, rgba(96,165,250,.16), transparent 55%);"
          data-parallax
          data-speed="0.18"
          data-axis="y"
          data-dir="up"
        />

        <div class="relative overflow-hidden card border border-[--border] bg-[rgba(255,255,255,0.02)] shadow-[--shadow-lg]">
          <div class="absolute inset-0 opacity-25" data-mouse-layer data-depth="0.35"
            style="background: linear-gradient(135deg, rgba(167,139,250,.25), rgba(240,171,252,.10), rgba(96,165,250,.18));"
          />
          <div class="absolute inset-0 opacity-[0.10]" data-mouse-layer data-depth="0.6"
            style="background-image: radial-gradient(rgba(255,255,255,0.12) 1px, transparent 1px); background-size: 18px 18px;"
          />

          <div class="relative p-4 sm:p-5" data-mouse-layer data-depth="1">
            <img
              src="https://images.unsplash.com/photo-1618005198919-d3d4b5a92eee?auto=format&fit=crop&w=1400&q=80&fm=webp"
              alt="Floating UI mockup"
              class="h-[360px] w-full card object-cover sm:h-[440px]"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <div class="pointer-events-none absolute inset-x-5 bottom-5 card border border-[--border] bg-[rgba(10,10,15,0.35)] px-4 py-3 backdrop-blur-xl">
              <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-[--muted]">Premium UI mockup</span>
                <span class="text-xs font-semibold text-[--muted2]">Scroll + hover for depth</span>
              </div>
            </div>
          </div>

          <!-- Mount the mouse parallax controller inside the visual block -->
          <MouseParallax client:load strength={14} />
        </div>
      </div>
    </div>
  </Container>
</section>

