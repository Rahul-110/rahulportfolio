---
import Section from "../components/ui/Section.astro";
import HorizontalScroll from "../components/motion/HorizontalScroll";
import { caseStudies } from "../content/caseStudies";
---

<Section
  id="work"
  eyebrow="Case studies"
  title="Work that shows thinking"
  subtitle="Each project highlights the problem, the process, and the final UI—so reviewers see your impact in minutes."
>
  <HorizontalScroll client:load />

  {/**
   * Mobile: vertical stack. Desktop: scroll-driven horizontal track (pinned).
   */}
  <div class="grid gap-5 md:hidden">
    {caseStudies.map((p) => (
      <article
        class="group relative overflow-hidden rounded-[--radius-lg] border border-[--border] bg-[--surface] shadow-[--shadow-sm] transition will-change-transform hover:shadow-[--shadow-glow]"
        data-tilt
      >
        <div class="relative aspect-[16/10] overflow-hidden">
          <img
            src={`${p.cover.src}&w=1200`}
            srcset={`${p.cover.src}&w=700 700w, ${p.cover.src}&w=1200 1200w`}
            sizes="(max-width: 768px) 100vw, 720px"
            alt={p.cover.alt}
            class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.04]"
            loading="lazy"
            decoding="async"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[rgba(0,0,0,0.78)] via-[rgba(0,0,0,0.28)] to-transparent opacity-90 transition duration-500 group-hover:opacity-100" />
          <div class="pointer-events-none absolute inset-0 opacity-20" style="background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(167,139,250,0.35), transparent 55%);" />
        </div>

        <div
          class="pointer-events-none absolute -right-20 -top-20 size-56 rounded-full blur-3xl opacity-0 transition duration-500 group-hover:opacity-100"
          style={`background: radial-gradient(circle, ${p.accent}, transparent 60%);`}
        />

        <div class="p-6">
          <p class="text-xs font-semibold tracking-[0.2em] text-[--muted2] uppercase">{p.role}</p>
          <h3 class="mt-3 font-display text-2xl tracking-tight">{p.title}</h3>
          <p class="mt-3 text-sm text-muted">
            {p.summary}
          </p>

          <div class="mt-5 flex flex-wrap gap-2">
            {p.tags.map((c) => (
              <span class="rounded-full border border-[--border] bg-[rgba(255,255,255,0.02)] px-3 py-1 text-xs font-semibold text-[--muted]">
                {c}
              </span>
            ))}
          </div>

          <div class="mt-7 flex items-center justify-between">
            <a
              class="inline-flex items-center gap-2 text-xs font-semibold text-[--text] opacity-90 transition group-hover:opacity-100"
              href={`/case-studies/${p.slug}`}
            >
              View Case Study <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="relative hidden md:block" data-hscroll-root>
    <div class="flex gap-5" data-hscroll-track>
      {caseStudies.map((p) => (
        <article
          class="group relative w-[520px] shrink-0 overflow-hidden rounded-[--radius-lg] border border-[--border] bg-[--surface] shadow-[--shadow-sm] transition will-change-transform hover:shadow-[--shadow-glow]"
          data-tilt
        >
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={`${p.cover.src}&w=1200`}
              srcset={`${p.cover.src}&w=900 900w, ${p.cover.src}&w=1200 1200w, ${p.cover.src}&w=1600 1600w`}
              sizes="520px"
              alt={p.cover.alt}
              class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.05]"
              loading="lazy"
              decoding="async"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[rgba(0,0,0,0.82)] via-[rgba(0,0,0,0.26)] to-transparent opacity-90 transition duration-500 group-hover:opacity-100" />
            <div class="pointer-events-none absolute inset-0 opacity-20" style="background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(167,139,250,0.35), transparent 55%);" />
            <div class="pointer-events-none absolute left-6 top-6 rounded-full border border-[--border] bg-[rgba(10,10,15,0.35)] px-3 py-1 text-xs font-semibold text-[--muted] backdrop-blur-xl">
              {p.role}
            </div>
            <a
              href={`/case-studies/${p.slug}`}
              class="absolute bottom-6 left-6 inline-flex items-center gap-2 rounded-full border border-[rgba(255,255,255,0.14)] bg-[rgba(10,10,15,0.35)] px-4 py-2 text-xs font-semibold text-[--text] backdrop-blur-xl opacity-0 transition duration-300 group-hover:opacity-100"
            >
              View Case Study <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
            </a>
          </div>

          <div
            class="pointer-events-none absolute -right-20 -top-20 size-56 rounded-full blur-3xl opacity-0 transition duration-500 group-hover:opacity-100"
            style={`background: radial-gradient(circle, ${p.accent}, transparent 60%);`}
          />

          <div class="p-7">
            <h3 class="font-display text-2xl tracking-tight">{p.title}</h3>
          <p class="mt-3 text-sm text-muted">
            {p.summary}
          </p>

          <div class="mt-5 flex flex-wrap gap-2">
            {p.tags.map((c) => (
              <span class="rounded-full border border-[--border] bg-[rgba(255,255,255,0.02)] px-3 py-1 text-xs font-semibold text-[--muted]">
                {c}
              </span>
            ))}
          </div>

            <div class="mt-7 flex items-center justify-between">
              <a class="text-xs font-semibold text-[--muted] hover:text-[--text]" href={`/case-studies/${p.slug}`}>
                Open detail
              </a>
              <span class="text-sm font-semibold text-[--muted] transition group-hover:translate-x-0.5" aria-hidden="true">
                →
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</Section>

